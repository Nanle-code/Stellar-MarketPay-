{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "HTTP Request Duration (p50/p95/p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(marketpay_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(marketpay_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(marketpay_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "HTTP Requests / sec by Status",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(marketpay_http_requests_total[5m])) by (status_code)",
          "legendFormat": "HTTP {{status_code}}"
        }
      ]
    },
    {
      "title": "HTTP Error Rate (5xx)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(marketpay_http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(marketpay_http_requests_total[5m])) * 100",
          "legendFormat": "Error %"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 1, "color": "yellow" }, { "value": 5, "color": "red" }] } }
      }
    },
    {
      "title": "Active WebSocket Connections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "ws_connections_active",
          "legendFormat": "Active"
        }
      ],
      "fieldConfig": {
        "defaults": { "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 100, "color": "yellow" }, { "value": 500, "color": "red" }] } }
      }
    },
    {
      "title": "Pending Notifications",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "notification_queue_pending",
          "legendFormat": "Pending"
        }
      ],
      "fieldConfig": {
        "defaults": { "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 50, "color": "yellow" }, { "color": "red", "value": 200 }] } }
      }
    },
    {
      "title": "DB Pool Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        { "expr": "pg_pool_total", "legendFormat": "Total" },
        { "expr": "pg_pool_idle", "legendFormat": "Idle" },
        { "expr": "pg_pool_waiting", "legendFormat": "Waiting" }
      ]
    },
    {
      "title": "Process Memory & CPU",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        { "expr": "process_resident_memory_bytes", "legendFormat": "Resident Memory" },
        { "expr": "rate(process_cpu_seconds_total[5m]) * 100", "legendFormat": "CPU %" }
      ]
    }
  ],
  "schemaVersion": 37,
  "style": "dark",
  "tags": ["stellar-marketpay", "observability"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Stellar MarketPay - Platform Overview",
  "uid": "stellar-marketpay-overview",
  "version": 1
}
